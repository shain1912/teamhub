# Supabase 연결 정보 (대시보드 > Project Settings > API)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# TeamHub MCP 서버(server/) 전용 — 서비스 롤 키 (RLS 우회, 절대 프론트엔드에 노출 금지)
# 대시보드 > Project Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# AI 비서(z.ai / GLM) — 서버(server/)의 /ai/chat 프록시가 사용. 키는 서버에만 둔다(프론트 노출 0).
GLM_API_KEY=YOUR-ZAI-API-KEY
# 선택: 모델/엔드포인트 오버라이드 (기본 glm-4.5 / https://api.z.ai/api/paas/v4)
# GLM_MODEL=glm-4.5
# GLM_BASE_URL=https://api.z.ai/api/paas/v4

# 프론트엔드: AI 프록시 URL (미설정 시 배포된 teamhub-mcp 기본값 사용)
# VITE_AI_PROXY_URL=https://teamhub-mcp.onrender.com
